# ---- Databricks connection (real connector) ----
# Option A: explicit creds
DBX_SERVER_HOSTNAME=adb-1234567890.0.azuredatabricks.net
DBX_HTTP_PATH=/sql/1.0/warehouses/abcdef1234567890
DBX_ACCESS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXX
# Option B: reuse Databricks CLI login (~/.databrickscfg). Set a profile name and
# a warehouse id; host/token are read from the cfg file.
DATABRICKS_CONFIG_PROFILE=DEFAULT
DBX_WAREHOUSE_ID=abcdef1234567890

# ---- Output tables / Genie / dashboard ----
DBX_CATALOG=main
DBX_SCHEMA=cost_optimizer
DBX_GENIE_SPACE_ID=01ef...      # create a Genie space over the cost tables, paste id

# ---- Analysis scope ----
DBX_LOOKBACK_DAYS=30
DBX_UTIL_LOOKBACK_DAYS=14

# ---- LLM (optional, narrative only) ----
ANTHROPIC_API_KEY=sk-ant-XXXX
DBX_LLM_MODEL=claude-opus-4-8

# ---- Email alerts (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=app-password-here
SMTP_USE_TLS=true
ALERT_FROM=alerts@example.com
ALERT_RECIPIENTS=finops@example.com,data-eng-lead@example.com

# ---- Alert thresholds (USD) ----
ALERT_MONTHLY_SPEND_USD=50000
ALERT_SINGLE_ENTITY_USD=5000
ALERT_IDENTIFIED_WASTE_USD=10000
